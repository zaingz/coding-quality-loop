{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hosts/claude-code/sessionstart_context.py\"",
            "timeout": 10,
            "statusMessage": "Loading Quality Loop context"
          }
        ]
      },
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hosts/claude-code/control_plane.py\" SessionStart codex",
            "timeout": 10,
            "statusMessage": "Starting Quality Loop control plane"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hosts/claude-code/control_plane.py\" SessionEnd codex",
            "timeout": 10,
            "statusMessage": "Recording session end"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hosts/claude-code/pretooluse_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking Quality Loop policy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/hosts/claude-code/stop_gate.py\"",
            "timeout": 600,
            "statusMessage": "Running Quality Loop stop gate"
          }
        ]
      }
    ]
  }
}
