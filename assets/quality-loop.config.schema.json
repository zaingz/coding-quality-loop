{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coding Quality Loop Orchestration Config",
  "type": "object",
  "required": ["version", "profiles", "steps"],
  "properties": {
    "version": {"type": "string"},
    "description": {"type": "string"},
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": {"type": "string"},
          "model": {"type": ["string", "null"]},
          "tools": {"type": "array", "items": {"type": "string"}},
          "independent_session": {"type": "boolean"},
          "deterministic": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step", "profile", "required_artifacts", "gates"],
        "properties": {
          "step": {
            "type": "string",
            "enum": ["INTAKE", "EXPLORE", "PLAN", "MINIMALITY_GATE", "IMPLEMENT_SLICE", "VERIFY", "REVIEW", "PACKAGE"]
          },
          "profile": {"type": "string"},
          "model_class": {
            "type": "string",
            "enum": ["cheap_fast", "strong_reasoning", "code_specialized", "deterministic"]
          },
          "tools": {"type": "array", "items": {"type": "string"}},
          "independent_session": {"type": "boolean"},
          "required_artifacts": {"type": "array", "items": {"type": "string"}},
          "gates": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "policy_guard": {"type": "object"},
    "routing_defaults": {"type": "object"},
    "memory": {
      "type": "object",
      "properties": {
        "lessons_store": {"type": "string", "enum": ["files"]},
        "location": {"type": "string", "enum": ["checked_in", "local"]},
        "recall_budget_chars": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    },
    "model_routing": {
      "type": "object",
      "description": "Per-model-class routing applied by setup-models. Optional v2.3 block; absent = no routing configured.",
      "properties": {
        "description": {"type": "string"},
        "host": {"type": ["string", "null"], "enum": ["claude-code", "droid", "codex", "pi", null]},
        "host_models": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "model": {"type": ["string", "null"]},
                "thinking": {"type": ["string", "null"], "enum": ["minimal", "low", "medium", "high", "xhigh", "max", null]},
                "note": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "agents": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
