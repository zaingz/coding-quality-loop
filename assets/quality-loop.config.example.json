{
  "$schema": "./quality-loop.config.schema.json",
  "version": "1.1.0",
  "description": "Agentic routing for the Coding Quality Loop. Map each profile to a real model on your platform. Models are placeholders; replace with your provider's identifiers.",
  "profiles": {
    "contract_agent": {"role": "INTAKE: goal -> task contract", "model": "<cheap-fast-model>", "tools": ["read"]},
    "repo_mapper": {"role": "EXPLORE: smallest relevant code map", "model": "<cheap-fast-model>", "tools": ["read", "search", "grep"]},
    "planner": {"role": "PLAN: design smallest correct change", "model": "<strong-reasoning-model>", "tools": ["read", "search"]},
    "minimality_reviewer": {"role": "MINIMALITY_GATE: pick highest valid rung", "model": "<strong-reasoning-model>", "tools": ["read"]},
    "implementer": {"role": "IMPLEMENT_SLICE: write the diff", "model": "<code-specialized-model>", "tools": ["read", "edit", "write", "exec"]},
    "verification_runner": {"role": "VERIFY: run checks, capture evidence", "model": "<cheap-fast-model>", "tools": ["exec"]},
    "fresh_reviewer": {"role": "REVIEW: independent diff review vs contract", "model": "<strong-reasoning-model>", "tools": ["read", "search"], "independent_session": true},
    "packager": {"role": "PACKAGE: assemble PR handoff", "model": "<cheap-fast-model>", "tools": ["read"]},
    "policy_guard": {"role": "Cross-cutting deterministic safety blocks", "model": null, "tools": ["hook"], "deterministic": true}
  },
  "steps": [
    {
      "step": "INTAKE",
      "profile": "contract_agent",
      "model_class": "cheap_fast",
      "tools": ["read"],
      "required_artifacts": ["task_contract"],
      "gates": ["contract_has_goal", "contract_has_acceptance_criteria", "contract_has_risk_tier"]
    },
    {
      "step": "EXPLORE",
      "profile": "repo_mapper",
      "model_class": "cheap_fast",
      "tools": ["read", "search", "grep"],
      "required_artifacts": ["repo_map"],
      "gates": ["likely_files_named"]
    },
    {
      "step": "PLAN",
      "profile": "planner",
      "model_class": "strong_reasoning",
      "tools": ["read", "search"],
      "required_artifacts": ["plan"],
      "gates": ["plan_names_files", "plan_names_verification"]
    },
    {
      "step": "MINIMALITY_GATE",
      "profile": "minimality_reviewer",
      "model_class": "strong_reasoning",
      "tools": ["read"],
      "required_artifacts": ["minimality_decision"],
      "gates": ["rung_chosen", "lower_rungs_rejected", "safety_exceptions_checked"]
    },
    {
      "step": "IMPLEMENT_SLICE",
      "profile": "implementer",
      "model_class": "code_specialized",
      "tools": ["read", "edit", "write", "exec"],
      "required_artifacts": ["diff"],
      "gates": ["diff_scoped_to_plan"]
    },
    {
      "step": "VERIFY",
      "profile": "verification_runner",
      "model_class": "cheap_fast",
      "tools": ["exec"],
      "required_artifacts": ["command_evidence"],
      "gates": ["evidence_matches_risk_tier"]
    },
    {
      "step": "REVIEW",
      "profile": "fresh_reviewer",
      "model_class": "strong_reasoning",
      "tools": ["read", "search"],
      "independent_session": true,
      "required_artifacts": ["review_verdict"],
      "gates": ["verdict_recorded", "findings_recorded"]
    },
    {
      "step": "PACKAGE",
      "profile": "packager",
      "model_class": "cheap_fast",
      "tools": ["read"],
      "required_artifacts": ["pr_handoff"],
      "gates": ["handoff_complete"]
    }
  ],
  "policy_guard": {
    "profile": "policy_guard",
    "enforcement": "deterministic",
    "applies_to": ["all_steps"],
    "block_or_escalate": [
      "secrets_or_credentials_in_diff",
      "destructive_migration_or_data_deletion",
      "payment_billing_auth_infra_change",
      "new_dependency_without_justification",
      "diff_exceeds_review_budget"
    ]
  },
  "routing_defaults": {
    "low": {"agents": ["implementer"], "policy_guard": true, "note": "One agent runs the whole loop."},
    "medium": {"agents": ["implementer", "fresh_reviewer", "verification_runner"], "policy_guard": true, "note": "Independent reviewer + real checks."},
    "high": {"agents": ["planner", "minimality_reviewer", "implementer", "verification_runner", "fresh_reviewer"], "policy_guard": true, "human_approval": true, "note": "Full split with enforced security/migration blocks."}
  }
}
