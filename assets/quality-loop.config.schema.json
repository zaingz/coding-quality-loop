{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coding Quality Loop Orchestration Config",
  "type": "object",
  "required": ["version", "profiles", "steps", "policy_guard", "routing_defaults"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"type": "string"},
    "description": {"type": "string"},
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": {"type": "string"},
          "model": {"type": ["string", "null"]},
          "tools": {"type": "array", "items": {"type": "string"}},
          "independent_session": {"type": "boolean"},
          "deterministic": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step", "profile", "required_artifacts", "gates"],
        "properties": {
          "step": {
            "type": "string",
            "enum": ["INTAKE", "EXPLORE", "PLAN", "MINIMALITY_GATE", "IMPLEMENT_SLICE", "VERIFY", "REVIEW", "PACKAGE", "RETROSPECT"]
          },
          "profile": {"type": "string"},
          "model_class": {
            "type": "string",
            "enum": ["cheap_fast", "strong_reasoning", "code_specialized", "deterministic"]
          },
          "tools": {"type": "array", "items": {"type": "string"}},
          "independent_session": {"type": "boolean"},
          "required_artifacts": {"type": "array", "items": {"type": "string"}},
          "gates": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "policy_guard": {"type": "object"},
    "routing_defaults": {
      "type": "object",
      "required": ["low", "medium", "high"],
      "properties": {
        "low": {"type": "object"},
        "medium": {"type": "object"},
        "high": {"type": "object"}
      },
      "additionalProperties": true
    },
    "advisor": {
      "type": "object",
      "description": "Optional Anthropic advisor-tool block. A cheap executor consults a stronger reasoning model at reasoning walls; the advisor never calls tools.",
      "properties": {
        "description": {"type": "string"},
        "enabled_for": {"type": "array", "items": {"type": "string", "enum": ["tiny", "small", "medium", "mission"]}},
        "executor_model_class": {"type": "string", "enum": ["cheap_fast", "strong_reasoning", "code_specialized"]},
        "advisor_model_class": {"type": "string", "enum": ["cheap_fast", "strong_reasoning", "code_specialized"]},
        "advisor_calls_tools": {"type": "boolean"},
        "max_uses": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    },
    "memory": {
      "type": "object",
      "properties": {
        "lessons_store": {"type": "string", "enum": ["files"]},
        "location": {"type": "string", "enum": ["checked_in", "local"]},
        "recall_budget_chars": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    },
    "model_routing": {
      "type": "object",
      "description": "Per-model-class routing applied by setup-models. Optional v2.3 block; absent = no routing configured.",
      "properties": {
        "description": {"type": "string"},
        "host": {"type": ["string", "null"], "enum": ["claude-code", "droid", "codex", "pi", null]},
        "host_models": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "model": {"type": ["string", "null"]},
                "family": {"type": ["string", "null"], "description": "Optional model family (e.g. claude, gpt, glm) for the reviewer-heterogeneity check. Wins over the well-known-prefix match; unknown families are skipped, never failed."},
                "thinking": {"type": ["string", "null"], "enum": ["minimal", "low", "medium", "high", "xhigh", "max", null], "description": "Reasoning effort. 'high' is the routine ceiling; effort is per-step, not per-task endurance, so xhigh/max only overthink and overspend each step. check-config rejects xhigh/max unless allow_overthink is true on this block."},
                "allow_overthink": {"type": "boolean", "description": "Set true to permit xhigh/max on this model_class for a genuinely ambiguous, architecture-sensitive case. Without it, check-config fails on xhigh/max."},
                "note": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "agents": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {"type": "string", "enum": ["cheap_fast", "strong_reasoning", "code_specialized"]},
              {
                "type": "object",
                "required": ["class"],
                "properties": {
                  "host": {"type": "string", "enum": ["claude-code", "droid", "codex", "pi"]},
                  "class": {"type": "string", "enum": ["cheap_fast", "strong_reasoning", "code_specialized"]},
                  "note": {"type": "string"}
                },
                "additionalProperties": true
              }
            ]
          },
          "description": "Agent file -> model_class. A plain string routes the agent on the default host (v4.1 shape); an object pins it to another host for multi-harness topologies."
        },
        "main_session": {
          "type": ["object", "null"],
          "description": "Declares where the implementer (main session) runs. Nothing is rewritten for it -- it feeds the cross-host reviewer-heterogeneity check, brief, and print-host output. Must resolve to a host: set host here or model_routing.host (check-config errors otherwise).",
          "properties": {
            "host": {"type": "string", "enum": ["claude-code", "droid", "codex", "pi"]},
            "class": {"type": "string", "enum": ["cheap_fast", "strong_reasoning", "code_specialized"]},
            "model": {"type": ["string", "null"]},
            "note": {"type": "string"}
          },
          "additionalProperties": true
        },
        "allow_same_family": {
          "type": "boolean",
          "description": "Explicit escape hatch: accept implementer and fresh_reviewer resolving to the same model FAMILY (never the same model). Without it, check-config fails same-family review on medium+."
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
