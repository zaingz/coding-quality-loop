{
  "$schema": "assets/quality-loop.config.schema.json",
  "version": "5.1.0",
  "description": "CQL's own orchestration config (dogfood). Since v6.5.0 this is the full orchestration shape consumers run \u2014 profiles/steps stay host-neutral placeholders; concrete routing lives in model_routing (pasted from assets/routing/max-intelligence.json, applied via setup-models, enforced by check-config: cross-family review is the load-bearing leg). Gate-config keys kept from the pre-v6.5.0 gate-only file: tests.path_markers teaches the gates that evals/cases/ IS this repo's pinned test-fixture suite (deliberately NOT evals/ wholesale: the eval runners embed weakening-marker fixture strings to test the detector itself). protect_harness is false HERE ONLY because this repo IS the harness: its gate scripts are the workpiece under constant edit; the always-on destructive-command layer still applies, and consumer installs keep the default (on). high_risk_paths pins hosts/ because hook code executes at tool time in consumer sessions and the v6.3.0 regressed outcome rode a hook-layer change (v6.2.0's rode the control add-on); memory.location local keeps dogfood lessons out of the shipped tree (a memory eval pins the checked-in store empty).",
  "tests": {
    "path_markers": [
      "evals/cases/"
    ]
  },
  "high_risk_paths": [
    "hosts/"
  ],
  "memory": {
    "location": "local"
  },
  "protect_harness": false,
  "profiles": {
    "orchestrator": {
      "role": "Mission: scope, classify, context, spec/validation contract, decompose, assign workers, collect findings, stop if unsafe",
      "model": "<strong-reasoning-model>",
      "tools": [
        "read",
        "search"
      ]
    },
    "contract_agent": {
      "role": "INTAKE: goal -> task contract",
      "model": "<cheap-fast-model>",
      "tools": [
        "read"
      ]
    },
    "repo_mapper": {
      "role": "EXPLORE/CONTEXT MAP: smallest relevant code map; findings not dumps",
      "model": "<cheap-fast-model>",
      "tools": [
        "read",
        "search",
        "grep"
      ]
    },
    "planner": {
      "role": "PLAN: design smallest correct change",
      "model": "<strong-reasoning-model>",
      "tools": [
        "read",
        "search"
      ]
    },
    "minimality_reviewer": {
      "role": "COMPLEXITY BRAKE: pick highest valid rung; simplicity review",
      "model": "<strong-reasoning-model>",
      "tools": [
        "read"
      ]
    },
    "implementer": {
      "role": "IMPLEMENT_SLICE: write the diff",
      "model": "<code-specialized-model>",
      "tools": [
        "read",
        "edit",
        "write",
        "exec"
      ]
    },
    "verification_runner": {
      "role": "VERIFY: run checks, capture evidence",
      "model": "<cheap-fast-model>",
      "tools": [
        "exec"
      ]
    },
    "fresh_reviewer": {
      "role": "INDEPENDENT REVIEW: validator; diff review vs validation contract",
      "model": "<strong-reasoning-model>",
      "tools": [
        "read",
        "search"
      ],
      "independent_session": true
    },
    "security_reviewer": {
      "role": "Risk boundaries only: auth, secrets, payments, PII, migrations, upload/download, network, shell, dependencies",
      "model": "<strong-reasoning-model>",
      "tools": [
        "read",
        "search"
      ],
      "independent_session": true
    },
    "packager": {
      "role": "SHIP/HANDOFF: assemble PR handoff + completion record",
      "model": "<cheap-fast-model>",
      "tools": [
        "read"
      ]
    },
    "retrospector": {
      "role": "RETROSPECT: convert a repeated failure into a durable harness update (rule/test/hook/checklist)",
      "model": "<strong-reasoning-model>",
      "tools": [
        "read",
        "write"
      ]
    },
    "policy_guard": {
      "role": "Cross-cutting deterministic safety blocks",
      "model": null,
      "tools": [
        "hook"
      ],
      "deterministic": true
    }
  },
  "steps": [
    {
      "step": "INTAKE",
      "profile": "contract_agent",
      "model_class": "cheap_fast",
      "tools": [
        "read"
      ],
      "required_artifacts": [
        "task_contract"
      ],
      "gates": [
        "contract_has_goal",
        "contract_has_acceptance_criteria",
        "contract_has_risk_tier"
      ]
    },
    {
      "step": "EXPLORE",
      "profile": "repo_mapper",
      "model_class": "cheap_fast",
      "tools": [
        "read",
        "search",
        "grep"
      ],
      "required_artifacts": [
        "repo_map"
      ],
      "gates": [
        "likely_files_named"
      ]
    },
    {
      "step": "MINIMALITY_GATE",
      "profile": "minimality_reviewer",
      "model_class": "strong_reasoning",
      "tools": [
        "read"
      ],
      "required_artifacts": [
        "minimality_decision"
      ],
      "gates": [
        "rung_chosen",
        "lower_rungs_rejected",
        "safety_exceptions_checked"
      ]
    },
    {
      "step": "PLAN",
      "profile": "planner",
      "model_class": "strong_reasoning",
      "tools": [
        "read",
        "search"
      ],
      "required_artifacts": [
        "plan"
      ],
      "gates": [
        "plan_names_files",
        "plan_names_verification"
      ]
    },
    {
      "step": "IMPLEMENT_SLICE",
      "profile": "implementer",
      "model_class": "code_specialized",
      "tools": [
        "read",
        "edit",
        "write",
        "exec"
      ],
      "required_artifacts": [
        "diff"
      ],
      "gates": [
        "diff_scoped_to_plan"
      ]
    },
    {
      "step": "VERIFY",
      "profile": "verification_runner",
      "model_class": "cheap_fast",
      "tools": [
        "exec"
      ],
      "required_artifacts": [
        "command_evidence"
      ],
      "gates": [
        "evidence_matches_risk_tier"
      ]
    },
    {
      "step": "REVIEW",
      "profile": "fresh_reviewer",
      "model_class": "strong_reasoning",
      "tools": [
        "read",
        "search"
      ],
      "independent_session": true,
      "required_artifacts": [
        "review_verdict"
      ],
      "gates": [
        "verdict_recorded",
        "findings_recorded"
      ]
    },
    {
      "step": "PACKAGE",
      "profile": "packager",
      "model_class": "cheap_fast",
      "tools": [
        "read"
      ],
      "required_artifacts": [
        "pr_handoff"
      ],
      "gates": [
        "handoff_complete"
      ]
    },
    {
      "step": "RETROSPECT",
      "profile": "retrospector",
      "model_class": "strong_reasoning",
      "tools": [
        "read",
        "write"
      ],
      "required_artifacts": [
        "harness_update"
      ],
      "gates": [
        "repeated_failure_converted_to_durable_harness_update"
      ]
    }
  ],
  "routing_defaults": {
    "low": {
      "agents": [
        "implementer"
      ],
      "policy_guard": true,
      "note": "One agent runs the whole loop."
    },
    "medium": {
      "agents": [
        "implementer",
        "fresh_reviewer",
        "verification_runner"
      ],
      "policy_guard": true,
      "note": "Independent reviewer + real checks."
    },
    "high": {
      "agents": [
        "orchestrator",
        "planner",
        "minimality_reviewer",
        "implementer",
        "verification_runner",
        "fresh_reviewer",
        "security_reviewer"
      ],
      "policy_guard": true,
      "human_approval": true,
      "security_reviewer_at_boundaries": true,
      "note": "Full split with enforced security/migration blocks; security_reviewer required at risk boundaries."
    }
  },
  "policy_guard": {
    "profile": "policy_guard",
    "enforcement": "deterministic",
    "applies_to": [
      "all_steps"
    ],
    "block_or_escalate": [
      "secrets_or_credentials_in_diff",
      "destructive_migration_or_data_deletion",
      "payment_billing_auth_infra_change",
      "new_dependency_without_justification",
      "diff_exceeds_review_budget"
    ]
  },
  "model_routing": {
    "as_of": "2026-07-12",
    "host": "claude-code",
    "host_models": {
      "claude-code": {
        "cheap_fast": {
          "model": "claude-sonnet-5",
          "family": "claude",
          "thinking": "low"
        },
        "strong_reasoning": {
          "model": "claude-fable-5",
          "family": "claude",
          "thinking": "high"
        },
        "code_specialized": {
          "model": "claude-fable-5",
          "family": "claude",
          "thinking": "high"
        }
      },
      "codex": {
        "strong_reasoning": {
          "model": "gpt-5.6-sol",
          "family": "gpt",
          "thinking": "high",
          "note": "Reviewer leg. Reviews stay advisory beneath deterministic gates; verify findings locally."
        }
      }
    },
    "agents": {
      "quality-loop-context-mapper": "cheap_fast",
      "quality-loop-planner": "strong_reasoning",
      "quality-loop-reviewer": {
        "host": "codex",
        "class": "strong_reasoning"
      },
      "quality-loop-security-reviewer": {
        "host": "codex",
        "class": "strong_reasoning"
      }
    },
    "main_session": {
      "host": "claude-code",
      "class": "code_specialized",
      "note": "Implementer runs in the Claude Code main session on Fable 5."
    },
    "allow_same_family": false
  }
}
