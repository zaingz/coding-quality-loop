{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hosts/claude-code/sessionstart_context.py"
            ],
            "timeout": 10,
            "statusMessage": "Loading Quality Loop context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hosts/claude-code/pretooluse_guard.py"
            ],
            "timeout": 10,
            "statusMessage": "Checking Quality Loop policy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hosts/claude-code/stop_gate.py"
            ],
            "timeout": 600,
            "statusMessage": "Running Quality Loop stop gate (terminal status re-executes evidence, up to 120s per command)"
          }
        ]
      }
    ]
  }
}
