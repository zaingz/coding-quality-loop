{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coding Quality Loop Agent Record",
  "type": "object",
  "required": [
    "task_id",
    "goal",
    "acceptance_criteria",
    "constraints",
    "non_goals",
    "assumptions",
    "risk_tier",
    "verification_plan",
    "status"
  ],
  "properties": {
    "task_id": {"type": "string"},
    "goal": {"type": "string", "minLength": 1},
    "task_class": {"type": ["string", "null"], "enum": ["tiny", "small", "medium", "mission", null]},
    "implementer": {"type": ["string", "null"]},
    "security_sensitive": {"type": "boolean"},
    "validation_contract": {"type": ["string", "object", "null"], "minLength": 1},
    "completion_record": {"type": ["string", "object", "null"], "minLength": 1, "description": "Inline object (with optional files_changed array) or a path to a completion-record file"},
    "repair_attempts": {"type": "integer", "minimum": 0},
    "repeated_failure": {"type": "boolean"},
    "run_metrics": {
      "type": "object",
      "description": "Optional per-run process-tax metrics (R3). All fields optional; check-record requires non-negative numbers and rejects unknown keys.",
      "properties": {
        "tokens_in": {"type": "number", "minimum": 0},
        "tokens_out": {"type": "number", "minimum": 0},
        "cost_usd": {"type": "number", "minimum": 0},
        "duration_sec": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "harness_update": {"type": ["string", "object", "null"], "minLength": 1},
    "models_used": {
      "type": "array",
      "description": "Optional per-role model attribution (v4.2 routing evidence): which model on which host ran each role, with attempts and optional cost. This is the R5 evidence base; cost per accepted record = sum(cost_usd) over records with status done and an approving independent_review.",
      "items": {
        "type": "object",
        "required": ["role", "model"],
        "properties": {
          "role": {"type": "string", "minLength": 1, "description": "implementer | fresh_reviewer | planner | context_mapper | security_reviewer | ..."},
          "host": {"type": "string", "description": "Harness the role ran on (claude-code, droid, codex, pi)"},
          "model": {"type": "string", "minLength": 1, "description": "Full pinned model id (aliases invite silent fallback)"},
          "thinking": {"type": "string"},
          "attempts": {"type": "integer", "minimum": 1},
          "tokens_in": {"type": "number", "minimum": 0},
          "tokens_out": {"type": "number", "minimum": 0},
          "cost_usd": {"type": "number", "minimum": 0}
        },
        "additionalProperties": true
      }
    },
    "escalations": {
      "type": "array",
      "description": "Optional model-tier escalation events (v4.2). CQL never triggers an escalation -- the host escalates; these entries make it auditable. verify-gates requires every failing_commands entry to match a commands_run entry with result=fail that carries an evidence handle: self-report escalation is not evidence, and a bare fail row is free to fabricate. Distinct from status=escalated, which is the human-input valve.",
      "items": {
        "type": "object",
        "required": ["step", "from_model", "to_model", "trigger", "failing_commands"],
        "properties": {
          "step": {"type": "string", "minLength": 1},
          "from_model": {"type": "string", "minLength": 1},
          "to_model": {"type": "string", "minLength": 1},
          "trigger": {"type": "string", "enum": ["verified_failure"], "description": "Enum of one on purpose: the only recordable escalation is one backed by failing check evidence."},
          "failing_commands": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "attempts": {"type": "integer", "minimum": 1},
          "at": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "independent_review": {
      "type": ["object", "null"],
      "required": ["verdict"],
      "properties": {
        "reviewer": {"type": "string"},
        "validator": {"type": "string"},
        "fresh_context": {"type": "boolean"},
        "patched": {"type": "boolean"},
        "verdict": {"type": "string", "enum": ["approve", "approved", "request_changes", "needs_discussion", "reject", "rejected", "fail", "failed", "blocked"]},
        "diff_sha256": {"type": "string", "description": "sha256 of the git diff at review time (attest-review); checked for freshness by verify-gates --against-diff"},
        "attested_at": {"type": "string"},
        "findings": {"type": "array", "items": {"type": ["object", "string"]}}
      },
      "additionalProperties": true
    },
    "security_review": {
      "type": ["object", "null"],
      "required": ["verdict"],
      "properties": {
        "reviewer": {"type": "string"},
        "fresh_context": {"type": "boolean"},
        "patched": {"type": "boolean"},
        "verdict": {"type": "string", "enum": ["approve", "approved", "request_changes", "needs_discussion", "reject", "rejected", "fail", "failed", "blocked"]},
        "diff_sha256": {"type": "string", "description": "sha256 of the git diff at review time (attest-review)"},
        "attested_at": {"type": "string"},
        "findings": {"type": "array", "items": {"type": ["object", "string"]}}
      },
      "additionalProperties": true
    },
    "acceptance_criteria": {
      "type": "array",
      "description": "Each criterion is either a plain string or an object {criterion, proving_command}. The proving_command is the check that proves the criterion; the verify umbrella AC-coverage gate matches it against commands_run with result=pass. String criteria remain valid for backward compatibility.",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "properties": {
              "criterion": {"type": "string", "description": "The acceptance criterion text"},
              "proving_command": {"type": "string", "description": "The command that proves this criterion; checked by the verify umbrella AC-coverage gate"}
            },
            "required": ["criterion", "proving_command"],
            "additionalProperties": true
          }
        ]
      }
    },
    "constraints": {"type": "array", "items": {"type": "string"}},
    "non_goals": {"type": "array", "items": {"type": "string"}},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "risk_tier": {"type": "string", "enum": ["low", "medium", "high"]},
    "verification_plan": {"type": "array", "items": {"type": "string"}},
    "repo_map": {
      "type": "object",
      "properties": {
        "entry_points": {"type": "array", "items": {"type": "string"}},
        "likely_files": {"type": "array", "items": {"type": "string"}},
        "callers_checked": {"type": "array", "items": {"type": "string"}},
        "tests": {"type": "array", "items": {"type": "string"}},
        "patterns_to_follow": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "minimality_decision": {
      "type": ["object", "null"],
      "properties": {
        "rung": {
          "type": "string",
          "enum": ["skip", "delete", "reuse", "stdlib", "native", "existing_dependency", "one_liner", "minimal_new_code"]
        },
        "reason": {"type": "string"},
        "rejected_lower_rungs": {"type": "array", "items": {"type": "object"}},
        "safety_exceptions_checked": {"type": "array", "items": {"type": "string"}}
      },
      "required": ["rung", "reason"]
    },
    "next_action": {"type": "string"},
    "plan": {"type": "array", "items": {"type": "string"}},
    "commands_run": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cmd", "result"],
        "properties": {
          "cmd": {"type": "string"},
          "class": {"type": "string"},
          "result": {"type": "string", "enum": ["pass", "fail", "blocked"]},
          "evidence": {"type": ["string", "object", "null"], "description": "A verifiable evidence handle (string) or structured object"},
          "red_green": {"type": "boolean", "description": "Marks a command to be replayed at base (expect fail) and HEAD (expect pass) by run-evidence --red-green"}
        },
        "additionalProperties": true
      }
    },
    "open_risks": {"type": "array", "items": {"type": "string"}},
    "review_findings": {"type": "array", "items": {"type": "string"}},
    "status": {
      "type": "string",
      "enum": ["intake", "explore", "plan", "minimality_gate", "implement", "verify", "review", "package", "retrospect", "done", "iterating", "escalated"]
    },
    "escalation_reason": {
      "type": "string",
      "minLength": 1,
      "description": "Required by the stop-gate valve when status is escalated: a non-empty reason makes the pause auditable."
    }
  },
  "additionalProperties": true
}
