__pycache__/
.quality-loop/memory/*.tmp
.quality-loop/rerun-*.json
.quality-loop/droid-prompts/
.quality-loop/runs/

# Dogfood run artifacts: per-task working dirs (plan/review/contract/completion)
# produced when this repo runs the loop on itself. The checked-in memory store
# under .quality-loop/memory/ is intentionally kept; these ad-hoc run dirs are not.
.quality-loop/readme-rebuild-*/

# Source-repo local host wiring generated by scripts/install.py.
# Consumer repos may choose to commit these; this repo keeps the generated
# copies local and commits only the source templates under hosts/ and examples/.
.claude/settings.json
.claude/settings.json.bak
.claude/skills/
.codex/
.cursor/
.factory/droids/
.pi/
.pre-commit-config.yaml
.pre-commit-config.yaml.bak
.github/workflows/quality-loop.yml
.github/workflows/quality-loop.yml.bak
